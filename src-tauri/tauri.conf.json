{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slide Forge",
  "version": "0.5.7",
  "identifier": "com.kentocell.slideforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Slide Forge",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost https://generativelanguage.googleapis.com https://api.groq.com https://api.anthropic.com https://api.openai.com https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Generate PowerPoint from prompts",
    "longDescription": "Slide Forge — プロンプトから PowerPoint を生成するデスクトップアプリ。Cloud / Local / Offline の 3 モード対応。",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kento-cell/slide-forge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBQkI2NDhDNjBCNDU5M0EKUldRNldiUmdqR1M3aWlDaTNabjEzYU4zQW5vUXdIa0FRNXZEemRvZGd3bjBzMVRDVlhNN3c4eDQK"
    }
  }
}
